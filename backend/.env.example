# Backend Environment Variables
# Copy this file to .env and fill in your actual values


# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/lostfound
MONGODB_URI=mongodb://localhost:27017/lostfound
# JWT Secret Key (use a strong random string in production)
JWT_SECRET=your-jwt-secret-here

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Gmail Credentials
GMAIL_USER=your-gmail-user-here
GMAIL_PASS=your-gmail-app-password-here

# AWS Credentials (DEPRECATED - kept for reference only, app now uses ImageKit)
# AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
# AWS_REGION=ap-south-1
# AWS_BUCKET_NAME=your-aws-bucket-name-here

# ImageKit Credentials (used for photo storage)
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key-here
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key-here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id